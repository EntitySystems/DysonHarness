@namespace Harness.UI.Components.Chat
@using DysonHarness
@inject IJSRuntime Js

<div class="chat-panel">
    <div @ref="_turnsEl"
         class="chat-panel__turns">
        @if (Turns.Count == 0)
        {
            <div class="empty-state">Start a session and send a prompt. Demo tools run staged mocks.</div>
        }
        else
        {
            @for (var i = 0; i < Turns.Count; i++)
            {
                var turn = Turns[i];
                <TurnBlock Turn="turn"
                           SessionBusy="SessionBusy"
                           IsLatestTurn="@(i == Turns.Count - 1)"
                           OnCancel="OnCancelPrompt" />
            }
        }
    </div>
    <Composer Disabled="@Disabled"
              SelectedSlugId="SelectedSlugId"
              SelectedSlugIdChanged="SelectedSlugIdChanged"
              SelectedAgentMode="SelectedAgentMode"
              SelectedAgentModeChanged="SelectedAgentModeChanged"
              GitBranch="GitBranch"
              OnSubmit="HandleSubmitAsync" />
</div>

@code {
    private ElementReference _turnsEl;
    private bool _forceStick;
    private bool _attached;
    private int _lastTurnCount;

    [Parameter] public IReadOnlyList<DysonAgentTurn> Turns { get; set; } = [];
    [Parameter] public bool Disabled { get; set; }
    /// <summary>Host busy (prompt in flight) — drives the latest-turn prompt spinner.</summary>
    [Parameter] public bool SessionBusy { get; set; }
    /// <summary>Cancel in-flight prompt (latest busy turn spinner).</summary>
    [Parameter] public EventCallback OnCancelPrompt { get; set; }
    [Parameter] public Guid? SelectedSlugId { get; set; }
    [Parameter] public EventCallback<Guid?> SelectedSlugIdChanged { get; set; }
    [Parameter] public string SelectedAgentMode { get; set; } = DysonAgentModes.Work;
    [Parameter] public EventCallback<string> SelectedAgentModeChanged { get; set; }
    [Parameter] public string? GitBranch { get; set; }
    [Parameter] public EventCallback<string> OnSubmit { get; set; }

    protected override void OnParametersSet()
    {
        // New turns (prompt send / resume) should re-attach to the bottom.
        if (Turns.Count != _lastTurnCount)
        {
            if (Turns.Count > _lastTurnCount)
                _forceStick = true;
            _lastTurnCount = Turns.Count;
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        try
        {
            if (!_attached)
            {
                await Js.InvokeVoidAsync("dysonChat.attach", _turnsEl);
                _attached = true;
            }

            if (_forceStick)
            {
                _forceStick = false;
                await Js.InvokeVoidAsync("dysonChat.setStick", _turnsEl, true);
            }

            // JS owns stick; no-op when user has scrolled away.
            await Js.InvokeVoidAsync("dysonChat.scrollToBottom", _turnsEl);
        }
        catch (JSException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private async Task HandleSubmitAsync(string prompt)
    {
        _forceStick = true;
        await OnSubmit.InvokeAsync(prompt);
    }
}
