@namespace Harness.UI.Components.Sessions
@using DysonHarness

<div class="session-list">
    <div class="sidebar__section-label">Sessions</div>
    <div class="btn-row" style="margin-bottom:8px;">
        <button type="button"
                class="btn btn-primary btn-icon"
                disabled="@(Busy || !CanCreate)"
                title="@(CanCreate ? "New session" : "Select a work directory first")"
                aria-label="New session"
                @onclick="OnNewAsync">
            <img src="icons/plus.svg" alt="" />
        </button>
        <button type="button"
                class="btn btn-ghost btn-icon"
                disabled="@Busy"
                title="Refresh"
                aria-label="Refresh"
                @onclick="OnRefreshAsync">
            <img src="icons/refresh.svg" alt="" />
        </button>
    </div>

    @if (!CanCreate)
    {
        <div class="list-item__meta" style="margin:0 0 8px;">Select a work directory to create sessions.</div>
    }

    @if (!string.IsNullOrEmpty(Error))
    {
        <div class="error-banner" style="margin:0 0 8px;">@Error</div>
    }

    <div class="list">
        @if (Sessions.Count == 0)
        {
            <div class="empty-state" style="padding:12px 4px;">No sessions yet</div>
        }
        else
        {
            @foreach (var session in Sessions)
            {
                var active = session.Id == ActiveSessionId;
                <button type="button"
                        class="list-item @(active ? "is-active" : null)"
                        disabled="@Busy"
                        @onclick="() => OnResumeAsync(session.Id)">
                    <span class="list-item__title">@(session.Title ?? "Untitled")</span>
                    <span class="list-item__meta mono">
                        @session.AgentMode · @session.Status · @session.LastActivityUtc.ToLocalTime().ToString("g")
                    </span>
                </button>
            }
        }
    </div>
</div>

@code {
    [Parameter] public IReadOnlyList<DysonSessionSummary> Sessions { get; set; } = [];
    [Parameter] public Guid? ActiveSessionId { get; set; }
    [Parameter] public bool Busy { get; set; }
    [Parameter] public bool CanCreate { get; set; } = true;
    [Parameter] public string? Error { get; set; }
    [Parameter] public EventCallback OnNew { get; set; }
    [Parameter] public EventCallback<Guid> OnResume { get; set; }
    [Parameter] public EventCallback OnRefresh { get; set; }

    private Task OnNewAsync() => OnNew.InvokeAsync();

    private Task OnResumeAsync(Guid id) => OnResume.InvokeAsync(id);

    private Task OnRefreshAsync() => OnRefresh.InvokeAsync();
}
