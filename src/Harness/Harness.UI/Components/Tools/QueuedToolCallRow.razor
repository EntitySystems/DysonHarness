@namespace Harness.UI.Components.Tools
@using DysonHarness

<div class="tool-row @(_expanded ? "tool-row--expanded" : null)">
    <button type="button"
            class="tool-row__header"
            aria-expanded="@(_expanded ? "true" : "false")"
            @onclick="ToggleExpanded">
        <span class="tool-row__name mono">@Call.ToolName</span>
        <span class="tool-status queued">Queued</span>
    </button>
    @if (_expanded)
    {
        <div class="tool-row__body">
            <div class="tool-row__meta mono">stage @Call.Stage · @Call.ArgumentsJson</div>
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public DysonToolCall Call { get; set; } = default!;

    private bool _expanded;

    private void ToggleExpanded() => _expanded = !_expanded;
}
